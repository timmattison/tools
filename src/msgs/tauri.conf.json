{
  "$schema": "https://raw.githubusercontent.com/nicerdicer/tauri-v2/main/tooling/cli/schema.json",
  "productName": "msgs",
  "version": "0.1.0",
  "identifier": "com.timmattison.msgs",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": "cd src/msgs/frontend && pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "msgs — iMessage Browser",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost"
    }
  }
}
